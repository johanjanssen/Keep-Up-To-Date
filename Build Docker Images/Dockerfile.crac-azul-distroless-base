# Image tag:  hello-conference:crac-azul-distroless-base
# Base:       gcr.io/distroless/base-debian12  (runtime)
#             azul/zulu-openjdk:25-jdk-crac     (build + jlink)
#
# CRaC – Coordinated Restore at Checkpoint
# ─────────────────────────────────────────
# CRaC lets a running JVM process be frozen to disk (checkpoint) and later
# restored from that snapshot.  On restore:
#   - All classes are already loaded          → no class-loading pause
#   - The JIT has already compiled hot paths  → peak throughput from request 1
#   - The Spring context is fully wired       → no bean-initialisation overhead
#   Startup time typically drops to 50–200 ms regardless of application size.
#
# Three-step build (handled by build-crac-azul-distroless-base.sh):
#   1. docker build   → this Dockerfile produces hello-conference:crac-azul-pre
#                       (minimal jlink CRaC JRE + app JAR, no checkpoint yet)
#   2. docker run     → starts the base image with --privileged so CRIU can
#                       write the checkpoint; Spring exits after context refresh
#   3. docker commit  → commits the stopped container (which now contains
#                       /crac-checkpoint) as hello-conference:crac-azul-distroless-base
#                       with the restore ENTRYPOINT
#
# No BuildKit insecure mode required.  --privileged is used only at build time
# (step 2); the final image also needs --privileged at runtime (see below).
#
# Runtime:
#   docker run --privileged -p 8080:8080 hello-conference:crac-azul-distroless-base
#   (CAP_CHECKPOINT_RESTORE requires Linux kernel 5.9+; --privileged is the
#   portable fallback for Docker Desktop and older kernels)
#
# Expected gains vs jlink-distroless-base (~158 MiB, ~3 s startup):
#   Startup    – ~50–200 ms  (JVM state fully restored, no class loading)
#   Memory     – ~130–160 MiB (heap restored to post-startup state)
#   Image size – ~400–700 MB  (checkpoint = full heap + JIT code dump)

# ── Stage 1: Maven build ──────────────────────────────────────
# Pin to a specific digest after first pull (see pull-base-images.sh).
FROM azul/zulu-openjdk:25-jdk-crac AS builder
WORKDIR /workspace

COPY mvnw mvnw
COPY .mvn .mvn
COPY pom.xml pom.xml

# Spring Framework 7.0 / Spring Boot 4.x requires 'org.crac:crac' on the
# classpath when spring.context.checkpoint=onRefresh is active.  The library
# bridges Spring's CRaC integration to the jdk.crac JDK module; without it
# the ApplicationContext throws IllegalStateException before the checkpoint.
# Version is managed by Spring Boot's parent BOM – no explicit version needed.
# sed targets the one </dependencies> in this pom.xml (the native Dockerfiles
# use the same pattern for the WebFlux swap).
RUN sed -i \
    's|</dependencies>|<dependency><groupId>org.crac</groupId><artifactId>crac</artifactId></dependency></dependencies>|' \
    pom.xml

RUN chmod +x mvnw && \
    ./mvnw dependency:go-offline -q --no-transfer-progress 2>/dev/null || true

COPY src src
RUN ./mvnw package -DskipTests --no-transfer-progress

# ── Stage 2: jlink – minimal CRaC-capable JRE ─────────────────
# Using the Azul Zulu CRaC JDK ensures the jlink output JRE contains the
# CRaC-patched JVM binary required for checkpoint and restore.
FROM azul/zulu-openjdk:25-jdk-crac AS jre-builder
WORKDIR /jlink-workspace

COPY --from=builder /workspace/target/HelloConference-0.0.1-SNAPSHOT.jar app.jar

# The jlink flag --strip-java-debug-attributes calls objcopy internally.
# The Azul image does not include binutils, so install it explicitly.
RUN apt-get update && \
    apt-get install -y --no-install-recommends binutils && \
    rm -rf /var/lib/apt/lists/*

# jdeps detects the real JDK module footprint of the fat JAR.
# Extra modules appended beyond jdeps detection:
#   java.management     – Spring metrics, JVM health checks
#   java.naming         – Spring JNDI lookups, log context naming
#   jdk.management      – JVM management MBeans
#   jdk.crypto.ec       – ECDHE cipher suites for TLS
#   jdk.crypto.cryptoki – PKCS#11 cryptographic provider
#   jdk.unsupported     – sun.misc.Unsafe (required by cglib, Spring proxies)
#   jdk.crac            – CRaC checkpoint/restore API; Spring Boot calls
#                         jdk.crac.Core.checkpointRestore() via reflection so
#                         jdeps will NOT detect it automatically
RUN set -eux; \
    jar xf app.jar; \
    DETECTED=$(jdeps \
        --ignore-missing-deps \
        --print-module-deps \
        --multi-release 25 \
        --recursive \
        --class-path 'BOOT-INF/lib/*' \
        BOOT-INF/classes \
        $(find BOOT-INF/lib -name '*.jar' | tr '\n' ' ') \
        2>/dev/null | tail -1); \
    echo "jdeps detected modules: ${DETECTED}"; \
    EXTRA="java.management,java.naming,jdk.management,jdk.crypto.ec,jdk.crypto.cryptoki,jdk.unsupported,jdk.crac"; \
    UNIQUE=$(echo "${DETECTED},${EXTRA}" | tr ',' '\n' | sort -u | paste -sd ','); \
    echo "jlink modules: ${UNIQUE}"; \
    jlink \
        --add-modules "${UNIQUE}" \
        --strip-debug \
        --strip-java-debug-attributes \
        --compress=zip-6 \
        --no-header-files \
        --no-man-pages \
        --output /jre-minimal

# Generate the base CDS archive so the restored JVM can share class metadata.
RUN /jre-minimal/bin/java -Xshare:dump 2>&1 | tail -5 && \
    echo "Base CDS: $(du -sh /jre-minimal/lib/server/classes.jsa | cut -f1)"

# Azul's JVM dynamically links libz.so.1 (Eclipse Temurin bundles it statically).
# gcr.io/distroless/base-debian12 does not include zlib, so locate the library
# via ldconfig and export it to a fixed path for the COPY in Stage 3.
RUN LIBZ=$(ldconfig -p 2>/dev/null | awk '/libz\.so\.1 /{print $NF; exit}') && \
    echo "Exporting ${LIBZ}" && \
    cp -L "${LIBZ}" /tmp/libz.so.1

# ── Stage 3: Base runtime (distroless + jlink CRaC JRE + app JAR) ────────────
# build-crac-azul-distroless-base.sh runs this image with --privileged to create
# the checkpoint, then docker commit bakes the checkpoint directory into the
# final image.
FROM gcr.io/distroless/base-debian12@sha256:e7e678c88c59e70e105a46549bb3fbfb3d732ee3b4afd3a19fdab2e15afaa6b3

ENV JAVA_HOME=/jre
ENV PATH="/jre/bin:${PATH}"

COPY --from=jre-builder /jre-minimal /jre
COPY --from=builder /workspace/target/HelloConference-0.0.1-SNAPSHOT.jar /app/app.jar
# libz.so.1 is absent from distroless/base; place it at the standard Debian
# multiarch path so the dynamic linker finds it without LD_LIBRARY_PATH.
COPY --from=jre-builder /tmp/libz.so.1 /usr/lib/x86_64-linux-gnu/libz.so.1

WORKDIR /app
EXPOSE 8080

# Placeholder ENTRYPOINT – overridden by the --change flag in the docker commit
# step done by build-crac-azul-distroless-base.sh.  Can also be used to test a
# cold (non-CRaC) start: docker run hello-conference:crac-azul-pre
ENTRYPOINT ["/jre/bin/java", "-jar", "app.jar"]
