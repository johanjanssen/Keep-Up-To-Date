# Runtime base: gcr.io/distroless/static-debian12  (Debian 12 Bookworm, ~2 MB)
# Binary is statically linked against musl libc → zero shared-lib dependencies.
# Techniques: musl static linking + -Os (size optimisation).
# Note: UPX compression is intentionally NOT used here. UPX decompresses the
# entire binary into a new anonymous memory region at startup, so it reduces
# image size on disk but significantly increases runtime memory usage.
# ⚠  First build: ~20 min (musl + zlib compiled from source + native compile).
#    Docker caches every toolchain layer; reruns on source changes are fast.
FROM ghcr.io/graalvm/native-image-community:25@sha256:0d936f32bb8acb5bc60c41b33e05f064d7a6aaf36b726538296c54949bd4a3c0 AS toolchain

RUN microdnf install -y \
        gcc make tar gzip curl findutils \
        --setopt=install_weak_deps=0 && \
    microdnf clean all

# musl libc – static only
RUN curl -fsSL https://musl.libc.org/releases/musl-1.2.5.tar.gz | tar -xz && \
    cd musl-1.2.5 && \
    ./configure --prefix=/usr/local/musl --disable-shared && \
    make -j$(nproc) install && \
    ln -s /usr/local/musl/bin/musl-gcc /usr/local/musl/bin/x86_64-linux-musl-gcc && \
    cd .. && rm -rf musl-1.2.5

ENV PATH="/usr/local/musl/bin:${PATH}"

# zlib – static build against musl (native-image needs libz.a for --static)
RUN curl -fsSL https://github.com/madler/zlib/releases/download/v1.3.1/zlib-1.3.1.tar.gz | tar -xz && \
    cd zlib-1.3.1 && \
    CC=musl-gcc ./configure --prefix=/usr/local/musl && \
    make -j$(nproc) libz.a && \
    cp libz.a /usr/local/musl/lib/ && \
    cp zlib.h zconf.h /usr/local/musl/include/ && \
    cd .. && rm -rf zlib-1.3.1

FROM toolchain AS builder
WORKDIR /workspace

COPY mvnw mvnw
COPY .mvn .mvn
COPY pom.xml pom.xml
RUN chmod +x mvnw && \
    ./mvnw dependency:go-offline -q --no-transfer-progress 2>/dev/null || true

COPY src src

# NATIVE_IMAGE_OPTIONS is picked up by native-image before any plugin flags
RUN NATIVE_IMAGE_OPTIONS="--static --libc=musl -Os" \
    ./mvnw -Pnative native:compile -DskipTests --no-transfer-progress

FROM gcr.io/distroless/static-debian12@sha256:9c346e4be81b5ca7ff31a0d89eaeade58b0f95cfd3baed1f36083ddb47ca3160
COPY --from=builder /workspace/target/HelloConference /HelloConference
EXPOSE 8080
ENTRYPOINT ["/HelloConference"]
