# Shell scripts — always LF, never CRLF (sh/bash breaks on Windows CRLF endings)
*.sh               text eol=lf
/mvnw              text eol=lf

# Windows batch files — always CRLF
*.cmd              text eol=crlf
*.bat              text eol=crlf

# Dockerfiles and common config — LF
Dockerfile*        text eol=lf
*.yml              text eol=lf
*.yaml             text eol=lf
*.json             text eol=lf
*.xml              text eol=lf
*.properties       text eol=lf
*.md               text eol=lf
